flowchart LR
    subgraph Browser["Browser (User)"]
        UI["React 18 SPA<br/>Vite dev :5173"]
        DnD["HTML5<br/>Drag-and-Drop"]
        UI --- DnD
    end

    subgraph Proxy["Vite Dev Proxy"]
        P["/api/* → :8000"]
    end

    subgraph Backend["Laravel 12 API (:8000)"]
        Routes["routes/api.php<br/>(17 routes)"]
        Controllers["Controllers<br/>Board / Column / Card"]
        Requests["Form Requests<br/>(8 validation classes)"]
        Service["CardService<br/>move + reorder<br/>(densify + tx)"]
        Resources["API Resources<br/>(3 transformers)"]

        Routes --> Controllers
        Controllers --> Requests
        Controllers --> Service
        Controllers --> Resources
    end

    subgraph Storage["Persistence"]
        SQLite[("SQLite<br/>database/database.sqlite")]
    end

    subgraph Domain["Domain Models (Eloquent)"]
        Board["Board"]
        Column["Column"]
        Card["Card"]
    end

    UI -- "fetch('/api/...')" --> P
    P -- "proxy pass" --> Routes
    Controllers --> Board
    Controllers --> Column
    Controllers --> Card
    Board -- "hasMany" --> Column
    Column -- "hasMany" --> Card
    Board -- "CASCADE on delete" --> Column
    Column -- "CASCADE on delete" --> Card
    Board -.-> SQLite
    Column -.-> SQLite
    Card -.-> SQLite

    classDef browser fill:#e3f2fd,stroke:#1976d2,color:#0d47a1
    classDef proxy fill:#fff3e0,stroke:#f57c00,color:#e65100
    classDef backend fill:#e8f5e9,stroke:#388e3c,color:#1b5e20
    classDef storage fill:#f3e5f5,stroke:#7b1fa2,color:#4a148c
    classDef domain fill:#fce4ec,stroke:#c2185b,color:#880e4f

    class UI,DnD browser
    class P proxy
    class Routes,Controllers,Requests,Service,Resources backend
    class SQLite storage
    class Board,Column,Card domain
